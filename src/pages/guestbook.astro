---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Guestbook | Manthan Ankolekar" description="Leave a note — I read every message.">
  <section class="section guestbook-hero">
    <div class="container">
      <h1 class="section-title">Guestbook</h1>
      <p class="section-subtitle">Drop a quick hello, feedback, or a question.</p>
    </div>
  </section>

  <section class="container guestbook-section">
    <div class="card">
      <form class="form" name="guestbook" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="guestbook" />
        <p class="hidden" style="display:none">
          <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
        </p>

        <div class="grid">
          <div class="field">
            <label for="name">Name</label>
            <input id="name" name="name" type="text" required placeholder="Your name" />
          </div>
          <div class="field">
            <label for="email">Email (optional)</label>
            <input id="email" name="email" type="email" placeholder="you@email.com" />
          </div>
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" rows="5" required placeholder="Write your note..."></textarea>
        </div>

        <button class="btn btn-primary btn-magnetic" type="submit">
          Sign guestbook
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
        </button>

        <p class="note">
          If you’d like a guaranteed reply, use the <a href="/contact">contact form</a>.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  .guestbook-hero {
    padding-top: 8rem;
    padding-bottom: 0;
  }

  .guestbook-section {
    padding-bottom: 5rem;
    max-width: 900px;
  }

  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .field label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .field input,
  .field textarea {
    padding: 0.75rem 1rem;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    transition: border-color var(--transition);
    outline: none;
  }

  .field input:focus,
  .field textarea:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
  }

  .note {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
  }

  .note a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 768px) {
    .guestbook-hero {
      padding-top: 6rem;
    }
    .card {
      padding: 1.25rem;
    }
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>

