---
import BaseLayout from '../layouts/BaseLayout.astro';

const updates = [
  {
    date: 'April 2026',
    items: [
      'Focusing on scaling full-stack applications with Astro and Node.js.',
      'Learning advanced patterns in Angular and RxJS.',
      'Reading "Designing Data-Intensive Applications".'
    ]
  },
  {
    date: 'January 2026',
    items: [
      'Wrapped up my role at Senwell Group.',
      'Experimenting with Edge Functions and KV stores.',
      'Rebuilding my personal portfolio.'
    ]
  }
];
---

<BaseLayout title="Now | Manthan Ankolekar" description="What I'm focused on right now.">
  <section class="section now-hero">
    <div class="container">
      <h1 class="section-title">Now</h1>
      <p class="section-subtitle">What I'm focused on right now. Inspired by <a href="https://sivers.org/now" target="_blank" style="color: var(--color-primary)">Derek Sivers</a>.</p>
    </div>
  </section>

  <section class="container now-content">
    {updates.map(update => (
      <div class="now-update">
        <h2>{update.date}</h2>
        <ul>
          {update.items.map(item => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .now-hero {
    padding-top: 8rem;
    padding-bottom: 2rem;
  }

  .now-content {
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .now-update {
    margin-bottom: 3rem;
    background: var(--color-bg-card);
    padding: 2rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .now-update h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    font-family: var(--font-mono);
  }

  .now-update ul {
    list-style: disc;
    padding-left: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--color-text);
    line-height: 1.6;
  }
</style>
