---
export const prerender = true;
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const snippets = await getCollection('snippets');
  return snippets.map(snippet => ({
    params: { slug: snippet.id },
    props: { snippet },
  }));
}

const { snippet } = Astro.props;
const { Content } = await render(snippet);
---

<BaseLayout title={`${snippet.data.title} | Snippets`} description={snippet.data.description}>
  <section class="section snippet-hero">
    <div class="container snippet-header">
      <a href="/snippets" class="back-link">← Back to Snippets</a>
      <h1 class="snippet-title">{snippet.data.title}</h1>
      <div class="snippet-meta">
        <time>{snippet.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <div class="snippet-tags">
          {snippet.data.tags.map(tag => (
            <span class="snippet-tag">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <article class="container snippet-content">
    <div class="prose snippet-prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .snippet-hero {
    padding-top: 8rem;
    padding-bottom: 2rem;
    background: var(--color-bg-alt);
    border-bottom: 1px solid var(--color-border);
  }

  .snippet-header {
    max-width: 800px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 1.5rem;
    text-decoration: none;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .snippet-title {
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--color-text);
  }

  .snippet-meta {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .snippet-tags {
    display: flex;
    gap: 0.5rem;
  }

  .snippet-tag {
    color: var(--color-accent-light);
    background: rgba(124, 58, 237, 0.1);
    padding: 0.1rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .snippet-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  /* Basic prose styling since we don't have Tailwind typography */
  .snippet-prose :global(h2) {
    font-size: 1.75rem;
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-text);
  }
  
  .snippet-prose :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .snippet-prose :global(pre) {
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 2rem;
    border: 1px solid var(--color-border);
  }

  .snippet-prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }
</style>
