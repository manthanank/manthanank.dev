---
import BaseLayout from '../layouts/BaseLayout.astro';

const equipment = [
  { category: 'Hardware', items: [
    { name: 'HP 15s"', desc: 'Intel Core i5 11th gen, 8gb RAM' },
    { name: 'BenQ GW2480', desc: '1080p 24" Monitor' },
    { name: 'Dell wireless mouse', desc: 'DellWM125' },
    { name: 'Dell wireless keyboard', desc: 'DellWM126' }
  ]},
  { category: 'Development', items: [
    { name: 'VS Code', desc: 'Primary Code Editor' },
    { name: 'GitHub Copilot', desc: 'AI Code Assistant' },
    { name: 'Figma', desc: 'Design & Prototyping' },
    { name: 'Postman', desc: 'API Testing' }
  ]},
  { category: 'Software', items: [
    { name: 'Raycast', desc: 'Productivity & Launcher' },
    { name: 'Arc Browser', desc: 'Daily Driver Browser' },
    { name: 'Notion', desc: 'Notes and Planning' },
    { name: 'Spotify', desc: 'Music' }
  ]}
];
---

<BaseLayout title="Uses | Manthan Ankolekar" description="Software, hardware, and tools I use on a daily basis.">
  <section class="section uses-hero">
    <div class="container">
      <h1 class="section-title">Uses</h1>
      <p class="section-subtitle">A list of hardware, software, and tools I use on a daily basis.</p>
    </div>
  </section>

  <section class="container uses-content">
    {equipment.map(group => (
      <div class="uses-category">
        <h2>{group.category}</h2>
        <ul class="uses-list">
          {group.items.map(item => (
            <li class="uses-item">
              <strong>{item.name}</strong> - <span>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</BaseLayout>

<style>
  .uses-hero {
    padding-top: 8rem;
    padding-bottom: 2rem;
  }

  .uses-content {
    max-width: 800px;
    margin: 0 auto;
    padding-bottom: 4rem;
  }

  .uses-category {
    margin-bottom: 3rem;
  }

  .uses-category h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
  }

  .uses-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .uses-item {
    background: var(--color-bg-alt);
    padding: 1rem 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .uses-item strong {
    color: var(--color-text);
    font-size: 1.1rem;
  }

  .uses-item span {
    color: var(--color-text-muted);
    margin-left: 0.5rem;
  }
</style>
