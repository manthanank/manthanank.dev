---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import Newsletter from '../../components/Newsletter.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const isDev = import.meta.env.DEV;
  const posts = await getCollection('blog', ({ data }) => isDev || !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Calculate reading time
const wordCount = post.body?.split(/\s+/g).length || 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

// Get related posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft && data.title !== post.data.title);
function normalizeTag(tag: string) {
  return tag.trim().toLowerCase();
}

const currentTags = new Set((post.data.tags || []).map(normalizeTag));

const relatedPosts = allPosts
  .map((p) => ({
    post: p,
    score: (p.data.tags || []).map(normalizeTag).reduce((acc: number, t: string) => acc + (currentTags.has(t) ? 1 : 0), 0),
  }))
  .sort((a, b) => (b.score - a.score) || (b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf()))
  .map((x) => x.post)
  .slice(0, 2);
---

<BaseLayout title={`${post.data.title} | Manthan Ankolekar`} description={post.data.description} ogId={post.id}>
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar" id="reading-progress-bar"></div>
  </div>
  <article class="blog-post">
    <div class="container">
      <header class="post-header">
        <a href="/blog" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Back to Blog
        </a>
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          <time>{formattedDate}</time>
          <span class="meta-divider">•</span>
          <span class="reading-time">{readingTime} min read</span>
          <span class="meta-divider">•</span>
          <span class="view-counter" id={`view-counter-${post.id}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            <span class="view-count-text skeleton">...</span>
          </span>
          {post.data.draft && <span class="draft-badge">Draft Preview</span>}
          {(post.data.series || (post.data.tags?.length ?? 0) > 0) && (
            <div class="post-taxonomy">
              {post.data.series && (
                <a class="post-series" href={`/series/${encodeURIComponent(post.data.series)}`}>Series: {post.data.series}</a>
              )}
              {(post.data.tags?.length ?? 0) > 0 && (
                <div class="post-tags">
                  {post.data.tags.map((tag: string) => (
                    <a class="post-tag" href={`/tags/${encodeURIComponent(tag)}`}>{tag}</a>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>
      </header>

      <div class="post-body">
        <div class="post-content" id="post-content">
          <Content />
        </div>
        <TableOfContents headings={headings} />
      </div>

      <div class="reaction-container">
        <button id={`like-btn-${post.id}`} class="like-btn" aria-label="Like this post">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="heart-icon"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          <span class="like-count">0</span>
        </button>
      </div>

      <Newsletter />

      <footer class="post-footer">
        <div class="footer-actions">
          <a href="/blog" class="btn btn-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            All Posts
          </a>

          <div class="share">
            <button class="share-btn" id="copy-post-link" type="button">
              <span class="share-label">Copy link</span>
            </button>
            <a
              class="share-btn"
              href={`https://x.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(canonicalURL.toString())}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="share-label">Share on X</span>
            </a>
            <a
              class="share-btn"
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL.toString())}`}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="share-label">LinkedIn</span>
            </a>
          </div>
        </div>
      </footer>

      {relatedPosts.length > 0 && (
        <section class="related-posts reveal">
          <h2 class="related-title">Continue Reading</h2>
          <div class="related-grid">
            {relatedPosts.map((post) => (
              <BlogCard
                title={post.data.title}
                excerpt={post.data.description}
                date={post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                tags={post.data.tags}
                url={`/blog/${post.id}`}
              />
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress-bar');
    if (!bar) return;

    const update = () => {
      const doc = document.documentElement;
      const total = doc.scrollHeight - (window.innerHeight || doc.clientHeight);
      const progress = total > 0 ? Math.round((window.scrollY / total) * 100) : 0;
      (bar as HTMLElement).style.transform = `scaleX(${progress / 100})`;
    };

    update();
    const key = '__readingProgressHandler';
    const w = window as any;
    if (w[key]) {
      window.removeEventListener('scroll', w[key]);
      window.removeEventListener('resize', w[key]);
    }
    w[key] = update;
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  }

  function initHeadingAnchors() {
    const root = document.getElementById('post-content');
    if (!root) return;
    const headings = root.querySelectorAll('h2[id], h3[id], h4[id]');

    headings.forEach((h) => {
      if (h.querySelector('.heading-anchor')) return;
      const id = h.getAttribute('id');
      if (!id) return;

      const a = document.createElement('a');
      a.className = 'heading-anchor';
      a.href = `#${id}`;
      a.setAttribute('aria-label', 'Copy link to this section');
      a.innerHTML = `
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l1.92-1.92a5 5 0 0 0-7.07-7.07l-1.1 1.1"/>
          <path d="M14 11a5 5 0 0 0-7.54-.54L4.54 12.38a5 5 0 0 0 7.07 7.07l1.1-1.1"/>
        </svg>
      `;
      h.appendChild(a);

      a.addEventListener('click', async (e) => {
        e.preventDefault();
        const url = `${window.location.origin}${window.location.pathname}#${id}`;
        try {
          await navigator.clipboard.writeText(url);
        } catch {
          // Fallback: update location hash at least
        }
        history.replaceState({}, '', `#${id}`);
        a.classList.add('copied');
        window.setTimeout(() => a.classList.remove('copied'), 1200);
      });
    });
  }

  function initShare() {
    const btn = document.getElementById('copy-post-link');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const url = window.location.href;
      try {
        await navigator.clipboard.writeText(url);
        btn.classList.add('copied');
        window.setTimeout(() => btn.classList.remove('copied'), 1200);
      } catch {
        // ignore
      }
    });
  }

  function initInteractions() {
    // 1. Setup real views
    const viewCounters = document.querySelectorAll('.view-counter');
    viewCounters.forEach(async (counter) => {
      const id = counter.id.replace('view-counter-', '');
      const textEl = counter.querySelector('.view-count-text');
      if (!textEl) return;
      
      try {
        const storageKey = `viewed_${id}`;
        const hasViewed = sessionStorage.getItem(storageKey);
        
        let method = 'POST';
        if (hasViewed) {
          method = 'GET';
        }

        const res = await fetch(`/api/views/${id}`, { method });
        const data = await res.json();
        
        if (!hasViewed) {
          sessionStorage.setItem(storageKey, 'true');
        }
        
        textEl.textContent = `${data.views || data.count || 0} views`;
        textEl.classList.remove('skeleton');
      } catch (e) {
        textEl.textContent = '0 views';
        textEl.classList.remove('skeleton');
      }
    });

    // 2. Setup likes
    const likeBtns = document.querySelectorAll('.like-btn');
    likeBtns.forEach(async (btn) => {
      const id = btn.id.replace('like-btn-', '');
      const countEl = btn.querySelector('.like-count');
      const icon = btn.querySelector('.heart-icon');
      if (!countEl || !icon) return;

      const storageKey = `liked_${id}`;
      let isLiked = localStorage.getItem(storageKey) === 'true';
      
      // Initial fetch
      try {
        const res = await fetch(`/api/likes/${id}`);
        const data = await res.json();
        countEl.textContent = data.likes.toString();
      } catch (e) {
        countEl.textContent = '0';
      }

      if (isLiked) {
        btn.classList.add('liked');
        icon.setAttribute('fill', 'var(--color-primary)');
        icon.setAttribute('stroke', 'var(--color-primary)');
      }

      // We need to keep track if a request is in progress to avoid spam
      let isLiking = false;

      btn.addEventListener('click', async () => {
        if (isLiking) return;
        isLiking = true;
        
        isLiked = !isLiked;
        localStorage.setItem(storageKey, isLiked.toString());
        
        // Optimistic UI update
        let currentLikes = parseInt(countEl.textContent || '0');
        
        if (isLiked) {
          countEl.textContent = (currentLikes + 1).toString();
          btn.classList.add('liked');
          icon.setAttribute('fill', 'var(--color-primary)');
          icon.setAttribute('stroke', 'var(--color-primary)');
          (btn as HTMLElement).style.transform = 'scale(1.2)';
          setTimeout(() => (btn as HTMLElement).style.transform = 'scale(1)', 150);
        } else {
          countEl.textContent = Math.max(0, currentLikes - 1).toString();
          btn.classList.remove('liked');
          icon.setAttribute('fill', 'none');
          icon.setAttribute('stroke', 'currentColor');
        }

        // Send to server
        try {
          const res = await fetch(`/api/likes/${id}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ action: isLiked ? 'like' : 'unlike' })
          });
          const data = await res.json();
          // Update with real truth from server just in case
          countEl.textContent = data.likes.toString();
        } catch (e) {
          // Revert on failure
          isLiked = !isLiked;
          localStorage.setItem(storageKey, isLiked.toString());
          if (isLiked) {
            btn.classList.add('liked');
            icon.setAttribute('fill', 'var(--color-primary)');
          } else {
            btn.classList.remove('liked');
            icon.setAttribute('fill', 'none');
          }
        } finally {
          isLiking = false;
        }
      });
    });
  }

  initReadingProgress();
  initHeadingAnchors();
  initShare();
  initInteractions();
  document.addEventListener('astro:after-swap', () => {
    initReadingProgress();
    initHeadingAnchors();
    initShare();
    initInteractions();
  });
</script>

<style>
  .reading-progress {
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    z-index: 101;
  }

  .reading-progress-bar {
    height: 100%;
    width: 100%;
    background: linear-gradient(90deg, var(--color-gradient-start), var(--color-gradient-end));
    transform-origin: left center;
    transform: scaleX(0);
  }

  .blog-post {
    padding-top: 8rem;
    padding-bottom: 5rem;
  }

  .post-header {
    max-width: 720px;
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .post-title {
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff, var(--color-text));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .view-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-family: var(--font-mono);
  }

  .view-count-text.skeleton {
    color: transparent;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
    animation: pulse 1.5s infinite;
  }

  .meta-divider {
    color: var(--color-border);
    font-size: 0.8rem;
  }

  .draft-badge {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    background: #f9e2af;
    color: #1e1e2e;
  }

  .post-taxonomy {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
  }

  .post-series {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(0, 212, 255, 0.08);
    padding: 0.25rem 0.6rem;
    border-radius: 6px;
    border: 1px solid rgba(0, 212, 255, 0.18);
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-tag {
    display: inline-flex;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-accent-light);
    background: rgba(124, 58, 237, 0.12);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  .post-tag:hover {
    color: var(--color-text);
    background: rgba(124, 58, 237, 0.22);
  }

  .post-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: 2rem;
    align-items: start;
  }

  .post-content {
    max-width: 720px;
    line-height: 1.85;
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .post-content :global(h2),
  .post-content :global(h3),
  .post-content :global(h4) {
    position: relative;
    scroll-margin-top: 90px;
  }

  .post-content :global(.heading-anchor) {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    margin-left: 0.5rem;
    opacity: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    transition: opacity var(--transition), color var(--transition), border-color var(--transition);
  }

  .post-content :global(h2:hover .heading-anchor),
  .post-content :global(h3:hover .heading-anchor),
  .post-content :global(h4:hover .heading-anchor) {
    opacity: 1;
  }

  .post-content :global(.heading-anchor:hover) {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .post-content :global(.heading-anchor.copied) {
    color: #22c55e;
    border-color: rgba(34, 197, 94, 0.4);
  }

  .post-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-text);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: rgba(0, 212, 255, 0.08);
    color: var(--color-primary);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
  }

  .post-content :global(pre) {
    background: #1e1e2e !important;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    line-height: 1.6;
  }

  .post-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--color-text);
    font-size: 0.85rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(ul li)::marker {
    color: var(--color-primary);
  }

  .post-content :global(ol li)::marker {
    color: var(--color-primary);
    font-weight: 600;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .reaction-container {
    display: flex;
    justify-content: center;
    margin: 4rem 0 2rem;
  }

  .like-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .like-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 212, 255, 0.1);
  }

  .like-btn.liked {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .like-btn svg {
    transition: all 0.2s ease;
  }

  .post-footer {
    max-width: 720px;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .footer-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .share {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: all var(--transition);
    font-size: 0.85rem;
  }

  .share-btn:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(0, 212, 255, 0.06);
  }

  #copy-post-link.copied {
    color: #22c55e;
    border-color: rgba(34, 197, 94, 0.4);
    background: rgba(34, 197, 94, 0.08);
  }

  .related-posts {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: 1px solid var(--color-border);
  }

  .related-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 2rem;
    background: linear-gradient(135deg, var(--color-gradient-start), var(--color-gradient-end));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(300px, 100%), 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .blog-post {
      padding-top: 6rem;
    }

    .post-header {
      margin-bottom: 2rem;
    }

    .post-title {
      font-size: clamp(1.5rem, 6vw, 2.2rem);
    }

    .post-meta {
      gap: 0.75rem;
      font-size: 0.9rem;
    }

    .post-content :global(h2) {
      font-size: 1.35rem;
      margin-top: 2rem;
    }

    .post-content :global(h3) {
      font-size: 1.1rem;
      margin-top: 1.5rem;
    }

    .post-content {
